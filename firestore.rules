rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Users: anyone can read; only the user themselves can write their own doc
    match /users/{userId} {
      allow read: if request.auth != null;
      allow create: if request.auth.uid == userId;
      allow update: if request.auth.uid == userId;
      allow delete: if false;
    }

    // Matches: all authenticated users can read; only admin UID can write
    // Replace YOUR_ADMIN_UID with your Firebase UID (find it in Auth > Users tab)
    match /matches/{matchId} {
      allow read: if request.auth != null;
      allow write: if request.auth.uid == "YOUR_ADMIN_UID";
    }

    // Picks: any authenticated user can read all picks (for group summaries)
    // Users can create/update their own picks only
    match /picks/{pickId} {
      allow read: if request.auth != null;
      allow create, update: if request.auth != null
        && request.resource.data.uid == request.auth.uid;
      allow delete: if false;
    }
  }
}
